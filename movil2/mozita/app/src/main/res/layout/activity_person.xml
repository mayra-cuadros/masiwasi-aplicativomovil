<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.PersonActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBarContacto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DBC9E0"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true"
        android:background="@mipmap/back_person">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dueño de la publicación"
                android:textColor="@color/textPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvNombreDueno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre: Cargando..."
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvEmailDueno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email: Cargando..."
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

<!--            <TextView-->
<!--                android:id="@+id/tvTelefonoDueno"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Teléfono: Cargando..."-->
<!--                android:textColor="@color/textPrimary"-->
<!--                android:textSize="18sp"-->
<!--                android:layout_marginBottom="12dp" />-->

            <TextView
                android:id="@+id/tvUbicacionDueno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ubicación: Cargando..."
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>