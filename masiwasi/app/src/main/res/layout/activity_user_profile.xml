<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="@mipmap/userprofilepage"
    tools:context=".ui.activities.UserProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imageViewUser"
                android:layout_width="160dp"
                android:layout_height="125dp"
                android:layout_marginBottom="12dp"
                android:layout_marginRight="15dp"
                android:scaleType="fitCenter"/>
<!--                app:srcCompat="@drawable/icon_user" -->


            <TextView
                android:id="@+id/textViewUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:text="Mark Z."
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@android:color/black"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnEditarPerfil"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Editar Perfil"
                android:layout_marginBottom="5dp"
                android:backgroundTint="@color/black"
                android:textColor="@android:color/white"
                android:paddingVertical="10dp" />

            <Button
                android:id="@+id/btnNuevaPublicacion"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Nueva Publicación"
                android:layout_marginBottom="5dp"
                android:backgroundTint="@color/black"
                android:textColor="@android:color/white"
                android:paddingVertical="10dp" />

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Cerrar Sesión"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white"
                android:paddingVertical="10dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="110dp"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginEnd="16dp"
            android:scaleType="centerCrop"/>
<!--            app:srcCompat="@drawable/meow" -->


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre: Demi"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/textView13"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edad: 8 Meses"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/textView12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sexo: Hembra"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btn_info1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="45dp"
                android:text="Información"
                android:backgroundTint="@color/black"
                android:textColor="@android:color/white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginEnd="16dp"
            android:scaleType="centerCrop"/>
<!--            app:srcCompat="@drawable/woof" -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Nombre: Fevi"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textView15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Edad: 2 Meses"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textView16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sexo: Macho"
                android:textSize="18sp" />

            <Button
                android:id="@+id/buttonInfo1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información"
                android:layout_marginTop="8dp"
                android:layout_marginLeft="45dp"
                android:backgroundTint="@color/black"
                android:textColor="@android:color/white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
